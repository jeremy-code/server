<config>
  <!-- Account -->
  <account-token v='${fah_config.token}'/>
  <machine-name value='oracle-cloud'/>

  <!-- Logging -->
  <verbosity v='6'/>

  <!-- Resource settings -->
  <cpus v='2'/>

  <!-- User information -->
  <passkey v='${fah_config.passkey}'/>
  <team v='${fah_config.team}'/>
  <user v='${fah_config.user}'/>
</config>
